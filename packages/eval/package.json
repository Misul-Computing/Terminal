{
	"name": "@misul/eval",
	"version": "0.2.0",
	"description": "Quality-per-dollar (QpD) eval meter for the Misul agent",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"bin": {
		"misul-eval": "dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/cli.js",
		"test": "vitest --run"
	},
	"dependencies": {
		"@misul/ai": "*",
		"@misul/terminal": "*"
	},
	"devDependencies": {
		"@opentelemetry/api": "1.9.0",
		"@types/node": "24.12.4",
		"shx": "0.4.0",
		"typescript": "5.9.3",
		"vitest": "3.2.4"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
