{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@misul/ai": ["./packages/ai/src/index.ts"],
			"@misul/ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@misul/ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@misul/ai/dist/*": ["./packages/ai/src/*"],
			"@misul/agent-core": ["./packages/agent/src/index.ts"],
			"@misul/agent-core/*": ["./packages/agent/src/*"],
			"@misul/terminal": ["./packages/terminal/src/index.ts"],
			"@misul/terminal/hooks": ["./packages/terminal/src/core/hooks/index.ts"],
			"@misul/terminal/*": ["./packages/terminal/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@misul/tui": ["./packages/tui/src/index.ts"],
			"@misul/tui/*": ["./packages/tui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/terminal/examples/**/*"],
	"exclude": ["**/dist/**", "packages/terminal/examples/extensions/gondolin/**"]
}
